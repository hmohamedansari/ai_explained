---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Sidebar from '@/components/layout/Sidebar.astro';
import MarkAsRead from '@/components/learn/MarkAsRead.tsx';
import Quiz from '@/components/quiz/Quiz.tsx';
import type { CollectionEntry } from 'astro:content';

interface Props {
  mod: CollectionEntry<'modules'>;
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
  quiz?: CollectionEntry<'quizzes'> | null;
}

const { mod, prev, next, quiz } = Astro.props;
const { title, description, track, moduleId, estimatedMinutes, volatility,
        lastReviewed, seoTitle, seoDescription } = mod.data;
const currentSlug = mod.slug.split('/')[1];

// SEO-resolved values — optional overrides fall back to display values
const metaTitle = seoTitle ?? title;
const metaDescription = seoDescription ?? description;

const editUrl = `https://github.com/hmohamedansari/ai-explained/edit/main/src/content/modules/${mod.slug}.mdx`;
const ogImagePath = `/og/${track}/${currentSlug}.png`;
const pageUrl = new URL(`/learn/${track}/${currentSlug}`, Astro.site).toString();
const trackLabel = track.replace(/-/g, ' ');
const trackUrl = new URL(`/learn/${track}`, Astro.site).toString();
const learnUrl = new URL('/learn', Astro.site).toString();

// Breadcrumb JSON-LD
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Learn', item: learnUrl },
    { '@type': 'ListItem', position: 2, name: trackLabel, item: trackUrl },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
};

// LearningResource JSON-LD
const learningResource = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: title,
  description: metaDescription,
  url: pageUrl,
  dateModified: lastReviewed,
  inLanguage: 'en',
  isAccessibleForFree: true,
  educationalUse: 'self-study',
};

const VOLATILITY_BADGE: Record<string, { label: string; classes: string }> = {
  volatile: { label: 'Fast-moving — verify before relying on this', classes: 'border-orange-500/30 text-orange-400 bg-orange-950/20' },
  emerging: { label: 'Emerging area',  classes: 'border-brand-500/30 text-brand-400 bg-brand-950/20' },
  stable:   { label: '',               classes: '' },
};

const badge = VOLATILITY_BADGE[volatility];
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={ogImagePath}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
    <script type="application/ld+json" set:html={JSON.stringify(learningResource)} />
  </Fragment>

  <Header />

  <div class="flex flex-1 min-h-0">
    <Sidebar track={track} currentSlug={currentSlug} />

    <div class="flex-1 min-w-0 flex flex-col">
      <main class="flex-1">
        <div class="max-w-3xl mx-auto px-6 py-12">

          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
            <a href="/learn" class="hover:text-brand-400 transition-colors">Tracks</a>
            <span aria-hidden="true">/</span>
            <a href={`/learn/${track}`} class="hover:text-brand-400 transition-colors capitalize">
              {trackLabel}
            </a>
            <span aria-hidden="true">/</span>
            <span class="text-slate-400 font-mono text-xs">{moduleId}</span>
          </nav>

          <!-- Module header -->
          <header class="mb-10">
            <div class="flex items-center gap-3 mb-4 flex-wrap">
              {badge.label && (
                <span class={`text-xs px-2 py-0.5 rounded-full border ${badge.classes}`}>
                  {badge.label}
                </span>
              )}
              {estimatedMinutes && (
                <span class="text-xs text-slate-500">{estimatedMinutes.layer1} min read</span>
              )}
            </div>
            <h1 class="text-3xl font-semibold text-white mb-3">{title}</h1>
            <p class="text-lg text-slate-400 leading-relaxed">{description}</p>
          </header>

          <!-- Module body -->
          <article class="prose-lesson">
            <slot />
          </article>

          <!-- Mark as read -->
          <div class="mt-12 pt-6 border-t border-white/10 flex items-center justify-between">
            <MarkAsRead moduleId={moduleId} client:load />
            <a
              href={editUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs text-slate-600 hover:text-brand-400 transition-colors"
            >
              ✏ Suggest an edit on GitHub
            </a>
          </div>

          <!-- Quiz -->
          {quiz && (
            <section class="mt-16 pt-10 border-t border-white/10">
              <Quiz
                title={quiz.data.title}
                moduleId={quiz.data.moduleId}
                questions={quiz.data.questions}
                client:load
              />
            </section>
          )}

          <!-- Prev / Next navigation -->
          <nav
            class="mt-16 pt-8 border-t border-white/10 grid grid-cols-2 gap-4"
            aria-label="Module navigation"
          >
            {prev ? (
              <a
                href={`/learn/${track}/${prev.slug}`}
                class="group flex flex-col gap-1 p-4 rounded-xl border border-white/10
                       hover:border-brand-500/40 hover:bg-surface-1 transition-all text-left"
              >
                <span class="text-xs text-slate-500 group-hover:text-brand-400 transition-colors">← Previous</span>
                <span class="text-sm font-medium text-slate-300">{prev.title}</span>
              </a>
            ) : <div />}

            {next ? (
              <a
                href={`/learn/${track}/${next.slug}`}
                class="group flex flex-col gap-1 p-4 rounded-xl border border-white/10
                       hover:border-brand-500/40 hover:bg-surface-1 transition-all text-right ml-auto w-full"
              >
                <span class="text-xs text-slate-500 group-hover:text-brand-400 transition-colors">Next →</span>
                <span class="text-sm font-medium text-slate-300">{next.title}</span>
              </a>
            ) : <div />}
          </nav>

        </div>
      </main>

      <Footer />
    </div>
  </div>
</BaseLayout>
