---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const modules = await getCollection('modules', ({ data }) =>
  !data.draft && data.status === 'published' && data.personas.includes('sre')
);
const sorted = modules.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="SRE / DevOps Path"
  description="Running AI workloads reliably and cost-efficiently in production."
>
  <Header />

  <main class="flex-1 w-full max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-16">
    <div class="mb-14">
      <div class="text-4xl sm:text-5xl mb-4 sm:mb-5">🔧</div>
      <h1 class="text-3xl sm:text-4xl font-semibold text-white mb-4">SRE / DevOps Path</h1>
      <p class="text-base sm:text-xl text-slate-400 max-w-2xl mb-6">
        You own the infrastructure. This path covers everything that matters when AI moves
        to production: VRAM budgets, serving architectures, cost management, supply chain
        security, and the observability stack that keeps you paged at 3am instead of midnight.
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="badge bg-brand-950/50 border border-brand-500/30 text-brand-300">Infrastructure first</span>
        <span class="badge bg-white/5 border border-white/10 text-slate-400">Production focus</span>
        <span class="badge bg-white/5 border border-white/10 text-slate-400">Cost & reliability</span>
      </div>
    </div>

    <div class="p-6 rounded-xl border border-white/10 bg-surface-1 mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-4">What you'll come away with</h2>
      <ul class="space-y-3">
        {[
          'How to run LLMs locally and in production — VRAM budgets, quantisation, vLLM serving',
          'The full observability stack: traces, costs, evals, and CI gates',
          'Supply chain security for AI: model weights, plugins, and dependency attacks',
          'Gateway patterns, caching layers, and latency engineering for p95/p99 SLOs',
        ].map(item => (
          <li class="flex items-start gap-3 text-slate-300 text-sm">
            <span class="text-brand-400 mt-0.5 shrink-0">✓</span>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="space-y-3">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Your curriculum</h2>
      {sorted.length === 0 ? (
        <p class="text-slate-500 text-sm">Modules for this path are being authored. Check back soon.</p>
      ) : sorted.map((mod) => (
        <a
          href={`/learn/${mod.slug}`}
          class="flex items-center gap-3 sm:gap-5 p-4 sm:p-5 rounded-xl border border-white/10 bg-surface-1
                 hover:border-brand-500/40 hover:bg-surface-2 transition-all group"
        >
          <div class="w-8 h-8 rounded-full border border-white/10 group-hover:border-brand-500/40
                      flex items-center justify-center text-xs font-mono text-slate-500
                      group-hover:text-brand-400 transition-colors shrink-0">
            {mod.data.moduleId}
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-white group-hover:text-brand-300 transition-colors mb-0.5">
              {mod.data.title}
            </p>
            <p class="text-sm text-slate-500 truncate">{mod.data.description}</p>
          </div>
          <span class="text-slate-600 group-hover:text-brand-400 transition-colors text-sm shrink-0">→</span>
        </a>
      ))}
    </div>

    {sorted.length > 0 && (
      <div class="mt-8">
        <a href={`/learn/${sorted[0].slug}`} class="btn-primary">Start here →</a>
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
