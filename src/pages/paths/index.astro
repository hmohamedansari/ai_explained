---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const paths = [
  {
    id: 'tech-leader',
    emoji: '🏛️',
    title: 'Tech Leader',
    description: 'The mental model, the strategic picture, and the decisions that matter — without wading through implementation detail.',
    href: '/paths/tech-leader',
    tags: ['Big picture', 'No deep code', 'Decision-making'],
  },
  {
    id: 'new-dev',
    emoji: '🌱',
    title: 'New Developer',
    description: 'Step-by-step from scratch. Lots of analogies, interactive exercises, and code you can actually run.',
    href: '/paths/new-dev',
    tags: ['Step-by-step', 'Analogies', 'Hands-on'],
  },
  {
    id: 'experienced-dev',
    emoji: '⚙️',
    title: 'Experienced Developer',
    description: 'Skip the hand-holding. Protocol internals, full code examples, and the edge cases worth knowing.',
    href: '/paths/experienced-dev',
    tags: ['Deep dives', 'Full code', 'Edge cases'],
  },
  {
    id: 'sre-devops',
    emoji: '🔧',
    title: 'SRE / DevOps',
    description: 'Infrastructure-first. How to deploy, monitor, and secure AI agents in production environments.',
    href: '/paths/sre-devops',
    tags: ['Production', 'Infrastructure', 'Security'],
  },
];
---

<BaseLayout title="Learning Paths" description="Choose your learning path based on your role and goals.">
  <Header />

  <main class="flex-1 max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-4xl font-semibold text-white mb-3">Learning Paths</h1>
      <p class="text-lg text-slate-400">
        Same concepts, tailored depth. Pick the path that fits your role.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {paths.map(p => (
        <a href={p.href} class="card group flex flex-col gap-4">
          <div class="text-4xl">{p.emoji}</div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-brand-300 transition-colors mb-2">
              {p.title}
            </h2>
            <p class="text-sm text-slate-400 leading-relaxed">{p.description}</p>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-auto">
            {p.tags.map(tag => (
              <span class="badge bg-white/5 text-slate-500">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
