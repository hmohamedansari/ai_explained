---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const paths = [
  {
    id: 'curious-beginner',
    emoji: '🌱',
    title: 'Curious Beginner',
    description: 'Zero coding required. Understand what AI actually is, how to read AI news intelligently, and why "just ask it nicely" isn\'t a safety strategy.',
    href: '/paths/curious-beginner',
    tags: ['No code', 'Big picture', 'Plain English'],
  },
  {
    id: 'tech-leader',
    emoji: '🏛️',
    title: 'Tech Leader',
    description: 'The mental model, the strategic picture, and the decisions that matter — ROI, risk surface, vendor strategy, and the EU AI Act.',
    href: '/paths/tech-leader',
    tags: ['Big picture', 'Minimal code', 'Decision-making'],
  },
  {
    id: 'new-dev',
    emoji: '🌿',
    title: 'Junior Developer',
    description: 'Your first deployable AI feature. Deliberately paced — evals before features, no conceptual gaps, working code throughout.',
    href: '/paths/new-dev',
    tags: ['Step-by-step', 'Working code', 'Evals first'],
  },
  {
    id: 'experienced-dev',
    emoji: '⚙️',
    title: 'Senior Developer',
    description: 'Production multi-agent systems. Evaluation-first architecture, protocol internals, typed contracts, and the failure modes worth knowing.',
    href: '/paths/experienced-dev',
    tags: ['Evaluation first', 'Full code', 'Production trade-offs'],
  },
  {
    id: 'sre-devops',
    emoji: '🔧',
    title: 'SRE / DevOps',
    description: 'Running AI workloads reliably and cheaply. VRAM budgets, serving architecture, cost management, supply chain security, and p95/p99 SLOs.',
    href: '/paths/sre-devops',
    tags: ['Infrastructure', 'Production', 'Cost & reliability'],
  },
];
---

<BaseLayout title="Learning Paths" description="Choose your learning path based on your role and goals.">
  <Header />

  <main class="flex-1 max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-4xl font-semibold text-white mb-3">Learning Paths</h1>
      <p class="text-lg text-slate-400">
        Same curriculum, tailored depth. Pick the path that fits your role — or{' '}
        <a href="/onboarding" class="text-brand-400 hover:text-brand-300 transition-colors">
          let us recommend one
        </a>.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {paths.map(p => (
        <a href={p.href} class="card group flex flex-col gap-4">
          <div class="text-4xl">{p.emoji}</div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-brand-300 transition-colors mb-2">
              {p.title}
            </h2>
            <p class="text-sm text-slate-400 leading-relaxed">{p.description}</p>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-auto">
            {p.tags.map(tag => (
              <span class="badge bg-white/5 text-slate-500">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
