---
import LessonLayout from '@/layouts/LessonLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('concepts', ({ data }) => !data.draft);
  return lessons.map(lesson => ({
    params: {
      module: lesson.data.module,
      lesson: lesson.slug,
    },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { module: moduleSlug } = Astro.params;

// Build prev/next within the module
const allLessons = await getCollection('concepts', ({ data }) => !data.draft);
const moduleLessons = allLessons
  .filter(l => l.data.module === moduleSlug)
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = moduleLessons.findIndex(l => l.slug === lesson.slug);
const prevLesson = currentIndex > 0
  ? { slug: moduleLessons[currentIndex - 1].slug, title: moduleLessons[currentIndex - 1].data.title }
  : null;
const nextLesson = currentIndex < moduleLessons.length - 1
  ? { slug: moduleLessons[currentIndex + 1].slug, title: moduleLessons[currentIndex + 1].data.title }
  : null;

const { Content } = await lesson.render();
---

<LessonLayout lesson={lesson} prevLesson={prevLesson} nextLesson={nextLesson}>
  <Content />
</LessonLayout>
