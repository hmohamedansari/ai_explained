---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Quiz from '@/components/quiz/Quiz';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('concepts', ({ data }) => !data.draft);
  const quizzes = await getCollection('quizzes');

  return lessons
    .filter(lesson => quizzes.some(q => q.data.concept === lesson.slug))
    .map(lesson => ({
      params: {
        module: lesson.data.module,
        lesson: lesson.slug,
      },
      props: { lesson },
    }));
}

const { lesson } = Astro.props;
const quizzes = await getCollection('quizzes');
const quiz = quizzes.find(q => q.data.concept === lesson.slug);
---

<BaseLayout title={`Quiz: ${lesson.data.title}`}>
  <Header />

  <main class="flex-1 max-w-3xl mx-auto px-6 py-16">
    <div class="mb-10">
      <a
        href={`/learn/${lesson.data.module}/${lesson.slug}`}
        class="text-sm text-slate-500 hover:text-brand-400 transition-colors mb-4 inline-block"
      >
        ← Back to lesson
      </a>
      <h1 class="text-3xl font-semibold text-white mb-2">Quiz: {lesson.data.title}</h1>
      <p class="text-slate-400">
        {quiz?.data.questions.length} questions. Check your understanding before moving on.
      </p>
    </div>

    {quiz ? (
      <Quiz
        client:load
        title={quiz.data.title}
        questions={quiz.data.questions}
      />
    ) : (
      <p class="text-slate-500">No quiz available for this lesson yet.</p>
    )}
  </main>

  <Footer />
</BaseLayout>
