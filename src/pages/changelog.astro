---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { Content as ChangelogContent } from '../../CHANGELOG.md';
---

<BaseLayout
  title="Changelog"
  description="All notable changes to AI Explained — new modules, site features, and curriculum updates."
>
  <Header />

  <main class="flex-1 max-w-3xl mx-auto px-6 py-16">
    <div class="mb-10">
      <h1 class="text-4xl font-semibold text-white mb-3">Changelog</h1>
      <p class="text-slate-400">
        What's new in AI Explained — new modules, features, and curriculum updates.
        Also available via <a href="/rss.xml" class="text-brand-400 hover:text-brand-300 transition-colors">RSS</a>.
      </p>
    </div>

    <article class="prose-lesson">
      <ChangelogContent />
    </article>
  </main>

  <Footer />
</BaseLayout>
