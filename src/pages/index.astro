---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const modules = await getCollection('modules');
const sortedModules = modules
  .filter(m => !m.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Home">
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <!-- Grid background -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(79,98,250,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(79,98,250,0.03)_1px,transparent_1px)] bg-[size:48px_48px]" />
      <!-- Glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-brand-600/10 rounded-full blur-3xl" />

      <div class="relative max-w-5xl mx-auto px-6 pt-24 pb-20 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-500/30 bg-brand-950/30 text-brand-300 text-xs font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse" />
          Open source · Community driven
        </div>

        <h1 class="text-5xl sm:text-6xl font-semibold text-white leading-tight tracking-tight mb-6">
          How AI Agents<br />
          <span class="text-brand-400">Actually Work</span>
        </h1>

        <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          Not hype, not magic — concrete mental models, real protocols, and working code.
          Built for tech leaders, developers, and SRE/DevOps engineers.
        </p>

        <div class="flex items-center justify-center gap-4 flex-wrap">
          <a href="/onboarding" class="btn-primary text-base px-7 py-3">
            Find my learning path →
          </a>
          <a href="/learn" class="btn-secondary text-base px-7 py-3">
            Browse all modules
          </a>
        </div>
      </div>
    </section>

    <!-- Modules -->
    <section class="max-w-5xl mx-auto px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl font-semibold text-white mb-2">Modules</h2>
          <p class="text-slate-400">Structured learning tracks, built to grow.</p>
        </div>
        <a href="/learn" class="text-sm text-brand-400 hover:text-brand-300 transition-colors">
          All modules →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {sortedModules.map(mod => (
          <a
            href={`/learn/${mod.id}`}
            class="card group flex flex-col gap-3"
          >
            <div class="text-3xl">{mod.data.icon}</div>
            <div>
              <h3 class="font-semibold text-white group-hover:text-brand-300 transition-colors mb-1">
                {mod.data.title}
              </h3>
              <p class="text-sm text-slate-400 leading-relaxed">{mod.data.description}</p>
            </div>
            <div class="mt-auto pt-3 border-t border-white/5 text-xs text-brand-400">
              Start learning →
            </div>
          </a>
        ))}

        <!-- Coming soon placeholder -->
        <div class="card opacity-50 flex flex-col gap-3 cursor-not-allowed">
          <div class="text-3xl grayscale">🔐</div>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-semibold text-white">Auth & Security</h3>
              <span class="badge bg-white/5 text-slate-500">Soon</span>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed">
              OAuth flows for remote MCP, credential scoping, security model deep dive.
            </p>
          </div>
        </div>

        <div class="card opacity-50 flex flex-col gap-3 cursor-not-allowed">
          <div class="text-3xl grayscale">🏠</div>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-semibold text-white">Homelab Integration</h3>
              <span class="badge bg-white/5 text-slate-500">Soon</span>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed">
              Running AI agents on Proxmox, K3s, Ollama, and LiteLLM.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Audience strip -->
    <section class="border-t border-white/10 bg-surface-1">
      <div class="max-w-5xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-semibold text-white text-center mb-10">Built for every role</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { emoji: '🏛️', role: 'Tech Leaders', desc: 'Mental models, not boilerplate' },
            { emoji: '🌱', role: 'New Developers', desc: 'Step-by-step with analogies' },
            { emoji: '⚙️', role: 'Experienced Devs', desc: 'Protocol internals + code' },
            { emoji: '🔧', role: 'SRE / DevOps', desc: 'Deploy, monitor, secure' },
          ].map(item => (
            <a
              href="/onboarding"
              class="text-center p-5 rounded-xl border border-white/10 hover:border-brand-500/30
                     hover:bg-surface-2 transition-all group"
            >
              <div class="text-3xl mb-3">{item.emoji}</div>
              <p class="font-medium text-white text-sm mb-1 group-hover:text-brand-300 transition-colors">{item.role}</p>
              <p class="text-xs text-slate-500">{item.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
