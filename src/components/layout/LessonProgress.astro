---
import type { CollectionEntry } from 'astro:content';

interface Props {
  lesson: CollectionEntry<'concepts'>;
}

const { lesson } = Astro.props;
const quizHref = `/learn/${lesson.data.module}/${lesson.slug}/quiz`;
---

<aside class="hidden xl:flex flex-col w-56 shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto border-l border-white/10 p-5">
  <div class="flex flex-col gap-4">
    <!-- Test yourself CTA -->
    <div class="p-4 rounded-xl border border-brand-500/30 bg-brand-950/30">
      <p class="text-sm font-medium text-white mb-1">Test yourself</p>
      <p class="text-xs text-slate-400 mb-3">Check your understanding with a quick quiz.</p>
      <a href={quizHref} class="btn-primary w-full justify-center text-xs py-2">
        Take quiz
      </a>
    </div>

    <!-- Estimated time -->
    {lesson.data.estimatedMinutes && (
      <div class="text-xs text-slate-500 flex items-center gap-2">
        <span>⏱</span>
        <span>{lesson.data.estimatedMinutes} min read</span>
      </div>
    )}

    <!-- Tags -->
    {lesson.data.tags.length > 0 && (
      <div>
        <p class="text-xs font-medium text-slate-500 uppercase tracking-widest mb-2">Topics</p>
        <div class="flex flex-wrap gap-1.5">
          {lesson.data.tags.map(tag => (
            <span class="badge bg-white/5 text-slate-400">{tag}</span>
          ))}
        </div>
      </div>
    )}
  </div>
</aside>
