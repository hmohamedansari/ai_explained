---
import type { CollectionEntry } from 'astro:content';

interface Props {
  mod: CollectionEntry<'modules'>;
}

const { mod } = Astro.props;
const quizHref = `/learn/${mod.data.track}/${mod.slug.split('/')[1]}/quiz`;
---

<aside class="hidden xl:flex flex-col w-56 shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto border-l border-white/10 p-5">
  <div class="flex flex-col gap-4">
    <!-- Test yourself CTA -->
    <div class="p-4 rounded-xl border border-brand-500/30 bg-brand-950/30">
      <p class="text-sm font-medium text-white mb-1">Test yourself</p>
      <p class="text-xs text-slate-400 mb-3">Check your understanding with a quick quiz.</p>
      <a href={quizHref} class="btn-primary w-full justify-center text-xs py-2">
        Take quiz
      </a>
    </div>

    <!-- Estimated time -->
    {mod.data.estimatedMinutes && (
      <div class="text-xs text-slate-500 flex items-center gap-2">
        <span>⏱</span>
        <span>{mod.data.estimatedMinutes.layer1} min read</span>
      </div>
    )}

    <!-- Volatility -->
    {mod.data.volatility !== 'stable' && (
      <div class="text-xs text-slate-500 flex items-center gap-2">
        <span>{mod.data.volatility === 'volatile' ? '⚠️' : '🔬'}</span>
        <span class="capitalize">{mod.data.volatility}</span>
      </div>
    )}
  </div>
</aside>
