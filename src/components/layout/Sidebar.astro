---
import { getCollection } from 'astro:content';

interface Props {
  currentModule: string;
  currentLesson: string;
}

const { currentModule, currentLesson } = Astro.props;

const allLessons = await getCollection('concepts', ({ data }) => !data.draft);
const moduleLessons = allLessons
  .filter(l => l.data.module === currentModule)
  .sort((a, b) => a.data.order - b.data.order);
---

<aside class="hidden lg:flex flex-col w-64 shrink-0 border-r border-white/10 bg-surface-1 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto">
  <div class="p-5">
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">
      {currentModule.replace(/-/g, ' ')}
    </p>

    <nav class="flex flex-col gap-0.5">
      {moduleLessons.map(lesson => {
        const isActive = lesson.slug === currentLesson;
        const href = `/learn/${currentModule}/${lesson.slug}`;
        return (
          <a
            href={href}
            class:list={[
              'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors',
              isActive
                ? 'bg-brand-600/20 text-brand-300 font-medium'
                : 'text-slate-400 hover:text-white hover:bg-white/5'
            ]}
          >
            <span class:list={[
              'w-1.5 h-1.5 rounded-full shrink-0',
              isActive ? 'bg-brand-400' : 'bg-white/20'
            ]} />
            {lesson.data.title}
          </a>
        );
      })}
    </nav>
  </div>
</aside>
